{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT:-.}}/hooks/run-hook.cmd\" session-start",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-.}}/hooks/post_edit_validate_prd.py\"",
            "timeout": 30,
            "statusMessage": "Validating Mozi PRD"
          },
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-.}}/hooks/post_edit_validate_spec.py\"",
            "timeout": 30,
            "statusMessage": "Validating Mozi SPEC"
          }
        ]
      }
    ]
  }
}
