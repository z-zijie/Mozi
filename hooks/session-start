#!/usr/bin/env bash
# SessionStart hook for Mozi plugin.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

using_mozi_content=$(cat "${PLUGIN_ROOT}/skills/using-mozi/SKILL.md" 2>&1 || echo "Error reading using-mozi skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_mozi_escaped=$(escape_for_json "$using_mozi_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have Mozi.\n\n**Below is the full content of your 'mozi:using-mozi' skill - your introduction to Mozi workflows. For task-specific workflows, use the relevant Mozi skill:**\n\n${using_mozi_escaped}\n</EXTREMELY_IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
